--[[
Custom UI Library para Roblox (em Lua)
Objetivo: Implementar funcionalidades semelhantes ao RedzLib, usando apenas instâncias-padrão do Roblox.
Coloque este código em um LocalScript dentro de StarterGui (ou rode em contexto de PlayerGui).
--]]

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- Configurações padrão de aparência (fácil de ajustar)
local THEME = {
    Background = Color3.fromRGB(24, 24, 24),
    Window = Color3.fromRGB(30, 30, 30),
    Accent = Color3.fromRGB(45, 170, 200),
    Button = Color3.fromRGB(40, 40, 40),
    ButtonHover = Color3.fromRGB(60, 60, 60),
    Text = Color3.fromRGB(235, 235, 235),
    Shadow = Color3.fromRGB(0, 0, 0),
}

-- Utility: cria instâncias com propriedades em massa
local function Create(className, props)
    local obj = Instance.new(className)
    if props then
        for k, v in pairs(props) do
            obj[k] = v
        end
    end
    return obj
end

-- Utility: cria sombra suave atrás de um frame usando UIGradient em um frame abaixo
local function CreateShadow(parent, size, position, zIndex)
    local shadow = Create("Frame", {
        Parent = parent,
        BackgroundColor3 = THEME.Shadow,
        BackgroundTransparency = 0.8,
        Size = size or UDim2.new(1, 8, 1, 8),
        Position = position or UDim2.new(0, -4, 0, -4),
        ZIndex = zIndex or 0,
    })
    local corner = Create("UICorner", { Parent = shadow, CornerRadius = UDim.new(0, 8) })
    local grad = Create("UIGradient", {
        Parent = shadow,
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.new(0,0,0)),
            ColorSequenceKeypoint.new(1, Color3.new(0,0,0)),
        }),
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.7),
            NumberSequenceKeypoint.new(1, 1),
        })
    })
    return shadow
end

-- Animação helper
local function Tween(instance, props, info)
    info = info or TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = TweenService:Create(instance, info, props)
    tween:Play()
    return tween
end

-- Salvar/Carregar configurações locais (session-local). Armazenamos JSON em um StringValue dentro de PlayerGui.
-- NOTA: Persistência entre sessões requer DataStore (server) ou APIs externas.
local SettingsStoreName = "CustomUILibrary_Settings"

local function SaveConfig(name, dataTable)
    local folder = PlayerGui:FindFirstChild(SettingsStoreName)
    if not folder then
        folder = Create("Folder", { Parent = PlayerGui, Name = SettingsStoreName })
    end
    local keyName = name or "default"
    local stringValue = folder:FindFirstChild(keyName)
    local json = HttpService:JSONEncode(dataTable or {})
    if stringValue then
        stringValue.Value = json
    else
        stringValue = Create("StringValue", { Parent = folder, Name = keyName, Value = json })
    end
    return true
end

local function LoadConfig(name)
    local folder = PlayerGui:FindFirstChild(SettingsStoreName)
    if not folder then return nil end
    local keyName = name or "default"
    local stringValue = folder:FindFirstChild(keyName)
    if not stringValue then return nil end
    local success, decoded = pcall(function()
        return HttpService:JSONDecode(stringValue.Value)
    end)
    return success and decoded or nil
end

-- MAIN WINDOW: cria a janela principal e provê métodos para abas
local MainWindow = {}
MainWindow.__index = MainWindow

-- Cria a interface principal (ScreenGui e elementos base)
-- title: string, subtitle: string, size: UDim2
function MainWindow.new(title, subtitle, size)
    local self = setmetatable({}, MainWindow)
    self.ScreenGui = Create("ScreenGui", { Parent = PlayerGui, Name = "CustomUILibrary_ScreenGui", ResetOnSpawn = false })
    self.Root = Create("Frame", {
        Parent = self.ScreenGui,
        Name = "MainWindow",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = size or UDim2.new(0, 700, 0, 420),
        BackgroundColor3 = THEME.Window,
        BackgroundTransparency = 0,
        ZIndex = 2,
    })
    Create("UICorner", { Parent = self.Root, CornerRadius = UDim.new(0, 10) })
    CreateShadow(self.ScreenGui, UDim2.new(0, (size and size.X.Offset or 700) + 12, 0, (size and size.Y.Offset or 420) + 12), UDim2.new(0.5, -((size and size.X.Offset or 700) / 2) - 6, 0.5, -((size and size.Y.Offset or 420) / 2) - 6), 1)

