local settingsTab = ui:CreateTab("Settings")

-- Cria seção dentro da aba
local generalSection = settingsTab:CreateSection("Geral")
generalSection.Container.Size = UDim2.new(1, 0, 0, 160) -- ajusta altura da seção conforme necessário

-- Adiciona um botão
local btnExample = UILibrary.CreateButton(generalSection.Content, {
    text = "Clique Me",
    callback = function()
        print("Botão clicado!")
    end
})
-- Adiciona um toggle
local toggleExample = UILibrary.CreateToggle(generalSection.Content, {
    text = "Ativar Modo",
    default = false,
    callback = function(state)
        print("Toggle agora:", state)
    end
})

-- Adiciona um slider
local sliderExample = UILibrary.CreateSlider(generalSection.Content, {
    text = "Velocidade",
    min = 0,
    max = 10,
    default = 5,
    decimals = 1,
    callback = function(val)
        print("Slider valor:", val)
    end
})

-- Adiciona um dropdown
local dropdownExample = UILibrary.CreateDropdown(generalSection.Content, {
    text = "Escolha uma opção",
    options = {"Opção A", "Opção B", "Opção C"},
    default = 1,
    callback = function(choice, index)
        print("Escolhido:", choice, index)
    end
})

-- Exemplo de salvar configurações locais (no PlayerGui como StringValue JSON)
local currentSettings = {
    toggle = toggleExample.GetState and toggleExample.GetState() or false,
    slider = sliderExample.GetValue and sliderExample.GetValue() or 0,
    dropdown = dropdownExample.GetSelection and dropdownExample.GetSelection() or nil,
}
UILibrary.SaveConfig("meu_perfil", currentSettings)

-- Exemplo de carregar configurações
local loaded = UILibrary.LoadConfig("meu_perfil")
if loaded then
    if loaded.toggle ~= nil and toggleExample.SetState then toggleExample.SetState(loaded.toggle) end
    if loaded.slider ~= nil and sliderExample.SetValue then sliderExample.SetValue(loaded.slider) end
    if loaded.dropdown ~= nil and dropdownExample.SetSelection then
        -- tenta localizar índice pelo valor
        local opts = {"Opção A", "Opção B", "Opção C"}
        for i, v in ipairs(opts) do
            if v == loaded.dropdown then
                dropdownExample.SetSelection(i)
                break
            end
        end
    end
end

-- A partir daqui, a interface está pronta e modular: você pode criar novas abas com ui:CreateTab("Nome"),
-- dentro das abas criar seções com tab:CreateSection("Seção"), e dentro das seções usar
-- UILibrary.CreateButton / CreateToggle / CreateSlider / CreateDropdown para adicionar elementos.

