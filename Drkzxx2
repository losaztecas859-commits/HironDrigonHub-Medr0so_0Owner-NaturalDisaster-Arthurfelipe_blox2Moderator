local Comnection = {
	Connection = {}
}

function Comnection:Connect(Name, Callback)
	if not self.Connection[Name] then
		self.Connection[Name] = {}
	end
	table.insert(self.Connection[Name], Callback)
end

function Comnection:FireConnection(Name, ...)
	if self.Connection[Name] then
		for _, Callback in self.Connection[Name] do
			Callback(...)
		end
	end
end

local function Create(ClassName, Parent, Props, Children)
	local New = Instance.new(ClassName)
	if type(Parent) == "table" then
		Children = Props
		Props = Parent
		Parent = nil
	end
	if Props then
		for Prop, Val in Props do
			New[Prop] = Val
		end
	end
	if Children then
		for _, Child in Children do
			Child.Parent = New
		end
	end
	if Parent then
		New.Parent = Parent
	end
	return New
end

local function SetProps(Instance, Props)
	for Prop, Val in Props do
		Instance[Prop] = Val
	end
	return Instance
end

local function SetChildren(Instance, Children)
	for _, Child in Children do
		Child.Parent = Instance
	end
	return Instance
end

local function Make(Type, Parent, Props)
	if Type == "Corner" then
		return Create("UICorner", Parent, {
			CornerRadius = Props or UDim.new(0, 8)
		})
	elseif Type == "Gradient" then
		local New = Create("UIGradient", Parent, Props)
		table.insert(redzlib.Instances, {
			Instance = New,
			Type = "Gradient"
		})
		return New
	elseif Type == "Stroke" then
		local New = Create("UIStroke", Parent, Props)
		table.insert(redzlib.Instances, {
			Instance = New,
			Type = "Stroke"
		})
		return New
	elseif Type == "Button" then
		return Create("TextButton", Parent, SetProps({
			AutoButtonColor = false,
			Text = "",
			BackgroundColor3 = Theme["Color Hub 2"]
		}, Props or {}))
	end
end

local function InsertTheme(Instance, Type)
	table.insert(redzlib.Instances, {
		Instance = Instance,
		Type = Type
	})
	return Instance
end

local function CreateTween(Configs)
	local Instance = Configs[1]
	local Prop = Configs[2]
	local NewVal = Configs[3]
	local Time = Configs[4] or 0.5
	local Wait = Configs[5] or false
	
	local Tween = TweenService:Create(Instance, TweenInfo.new(Time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		[Prop] = NewVal
	})
	Tween:Play()
	if Wait then
		Tween.Completed:Wait()
	end
	return Tween
end

local function MakeDrag(Instance)
	local Dragging, DragInput, DragStart, StartPos
	
	Instance.InputBegan:Connect(function(Input)
		if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
			Dragging = true
			DragStart = Input.Position
			StartPos = Instance.Position
			
			Input.Changed:Connect(function()
				if Input.UserInputState == Enum.UserInputState.End then
					Dragging = false
				end
			end)
		end
	end)
	
	Instance.InputChanged:Connect(function(Input)
		if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
			DragInput = Input
		end
	end)
	
	UserInputService.InputChanged:Connect(function(Input)
		if Input == DragInput and Dragging then
			local Delta = Input.Position - DragStart
			Instance.Position = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + Delta.X, StartPos.Y.Scale, StartPos.Y.Offset + Delta.Y)
		end
	end)
	return Instance
end

local function SaveJson(Name, Table)
	if writefile then
		writefile(Name, HttpService:JSONEncode(Table))
	end
end

local function VerifyTheme(NewTheme)
	return redzlib.Themes[NewTheme] ~= nil
end

local function ConnectSave(Instance, Callback)
	Instance.InputEnded:Connect(function(Input)
		if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
			Callback()
		end
	end)
end

