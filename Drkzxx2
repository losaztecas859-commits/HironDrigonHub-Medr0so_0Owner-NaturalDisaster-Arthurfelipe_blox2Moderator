			local function Open()
				DropdownFrame.Visible = not DropdownFrame.Visible
				DropdownFrame.Position = UDim2.fromOffset(SelectedFrame.AbsolutePosition.X, SelectedFrame.AbsolutePosition.Y + SelectedFrame.AbsoluteSize.Y + 5)
				DropdownFrame.Size = UDim2.fromOffset(150, math.min(#Options * 22, 100))
			end
			
			Button.Activated:Connect(Open)
			
			local function Set(Val)
				SelectedLabel.Text = Val
				if Flag then Flags[Flag] = Val end
				Funcs:FireCallback(Callback, Val)
				DropdownFrame.Visible = false
			end
			
			local function Refresh(NewOptions)
				Options = NewOptions
				for _, v in DropdownFrame:GetChildren() do
					if v:IsA("TextButton") then v:Destroy() end
				end
				for _, v in Options do
					local OptionBtn = Create("TextButton", DropdownFrame, {
						Size = UDim2.new(1, 0, 0, 20),
						BackgroundTransparency = 1,
						Text = v,
						Font = Enum.Font.GothamMedium,
						TextSize = 10,
						TextColor3 = Theme["Color Text"],
						AutoButtonColor = false
					})
					OptionBtn.Activated:Connect(function() Set(v) end)
				end
			end
			
			Refresh(Options)
			if Default ~= "" then Set(Default) end
			
			local Dropdown = {}
			function Dropdown:Set(Val) Set(Val) end
			function Dropdown:Refresh(Val) Refresh(Val) end
			function Dropdown:Visible(...) Funcs:ToggleVisible(Button, ...) end
			function Dropdown:Destroy() Button:Destroy() end
			return Dropdown
		end
		
