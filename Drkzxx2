		function Tab:AddSlider(Configs)
			local SName = Configs[1] or Configs.Name or Configs.Title or "Slider"
			local SDesc = Configs.Desc or Configs.Description or ""
			local Min = Configs.Min or Configs[2] or 0
			local Max = Configs.Max or Configs[3] or 100
			local Default = Configs.Default or Configs[4] or Min
			local Callback = Funcs:GetCallback(Configs, 5)
			local Flag = Configs.Flag or false
			
			local Button, LabelFunc = ButtonFrame(Container, SName, SDesc, UDim2.new(1, -180))
			
			local SliderFrame = Create("Frame", Button, {
				Size = UDim2.new(0, 150, 0, 4),
				Position = UDim2.new(1, -10, 0.5),
				AnchorPoint = Vector2.new(1, 0.5),
				BackgroundColor3 = Color3.fromRGB(40, 40, 40)
			})Make("Corner", SliderFrame)
			
			local SliderFill = InsertTheme(Create("Frame", SliderFrame, {
				Size = UDim2.fromScale(0, 1),
				BackgroundColor3 = Theme["Color Theme"]
			}), "Theme")Make("Corner", SliderFill)
			
			local SliderBall = Create("Frame", SliderFrame, {
				Size = UDim2.fromOffset(10, 10),
				Position = UDim2.fromScale(0, 0.5),
				AnchorPoint = Vector2.new(0.5, 0.5),
				BackgroundColor3 = Color3.fromRGB(255, 255, 255)
			})Make("Corner", SliderBall, UDim.new(1, 0))
			
			local ValueLabel = InsertTheme(Create("TextLabel", SliderFrame, {
				Size = UDim2.fromScale(1, 1),
				Position = UDim2.new(0, 0, -1.5, 0),
				BackgroundTransparency = 1,
				Text = tostring(Default),
				Font = Enum.Font.GothamBold,
				TextSize = 10,
				TextColor3 = Theme["Color Text"],
				TextXAlignment = "Right"
			}), "Text")
			
			local Value = Default
			local function Set(Val)
				Value = math.clamp(Val, Min, Max)
				if Flag then Flags[Flag] = Value end
				
				local Percent = (Value - Min) / (Max - Min)
				SliderFill.Size = UDim2.fromScale(Percent, 1)
				SliderBall.Position = UDim2.fromScale(Percent, 0.5)
				ValueLabel.Text = tostring(Value)
				Funcs:FireCallback(Callback, Value)
			end
			
			local Dragging = false
			local function Update()
				local MousePos = UserInputService:GetMouseLocation().X
				local FramePos = SliderFrame.AbsolutePosition.X
				local FrameSize = SliderFrame.AbsoluteSize.X
				local Percent = math.clamp((MousePos - FramePos) / FrameSize, 0, 1)
				Set(math.floor(Min + (Max - Min) * Percent))
			end
			
			SliderFrame.InputBegan:Connect(function(Input)
				if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
					Dragging = true
					Update()
				end
			end)
			
			UserInputService.InputEnded:Connect(function(Input)
				if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
					Dragging = false
				end
			end)
			
			UserInputService.InputChanged:Connect(function(Input)
				if Dragging and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
					Update()
				end
			end)
			
			if Flag then Flags[Flag] = Value end
			Set(Value)
			
			local Slider = {}
			function Slider:Set(Val) Set(Val) end
			function Slider:Visible(...) Funcs:ToggleVisible(Button, ...) end
			function Slider:Destroy() Button:Destroy() end
			return Slider
		end
		
