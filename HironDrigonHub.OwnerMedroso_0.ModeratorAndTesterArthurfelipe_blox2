-- ===== LOOPFLING PLAYER SELECIONADO V2 (FIX REAL) =====
local LoopFlingV2 = false
local OriginalCFrame
local TargetRespawnConn
local ReturnLoop
local V2Spin

local function stopLoopFlingV2()
LoopFlingV2 = false

if TargetRespawnConn then
TargetRespawnConn:Disconnect()
TargetRespawnConn = nil
end

if ReturnLoop then
task.cancel(ReturnLoop)
ReturnLoop = nil
end

if V2Spin then
V2Spin:Destroy()
V2Spin = nil
end

setNoclip(false)

end

local function startLoopFlingV2()
if not SelectedPlayer then return end
local target = Players:FindFirstChild(SelectedPlayer)
if not target then return end

local char = LocalPlayer.Character
if not char then return end
local hrp = char:FindFirstChild("HumanoidRootPart")
if not hrp then return end

OriginalCFrame = hrp.CFrame
setNoclip(true)

-- cria spin exclusivo do V2
V2Spin = Instance.new("BodyAngularVelocity")
V2Spin.AngularVelocity = Vector3.new(0,200000,0)
V2Spin.MaxTorque = Vector3.new(0,math.huge,0)
V2Spin.Parent = hrp

local function tpToTarget()
if not LoopFlingV2 then return end
if not target.Character then return end
local thrp = target.Character:FindFirstChild("HumanoidRootPart")
if thrp then
hrp.CFrame = thrp.CFrame
end
end

-- TP inicial
task.wait(0.2)
tpToTarget()

-- Quando o alvo renascer → TP + fling de novo
if TargetRespawnConn then TargetRespawnConn:Disconnect() end
TargetRespawnConn = target.CharacterAdded:Connect(function()
task.wait(0.4)
tpToTarget()
end)

-- Volta pro lugar original a cada 2s
ReturnLoop = task.spawn(function()
while LoopFlingV2 do
task.wait(2)
if hrp and OriginalCFrame then
hrp.CFrame = OriginalCFrame
end
end
end)

end

