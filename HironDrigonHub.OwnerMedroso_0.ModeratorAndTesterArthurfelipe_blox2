-- ===== DRONE CAMERA / FREECAM =====
local DroneEnabled = false
local DroneCamera
local DroneSpeed = 50
local TouchControl = {}
local TouchPos = Vector2.new(0,0)
local Rotation = Vector2.new(0,0)

TabTroll:AddToggle({
Name = "Drone Camera",
Default = false,
Callback = function(state)
local char = LocalPlayer.Character
local cam = workspace.CurrentCamera
DroneEnabled = state

if state then
-- Desativar personagem e ativar freecam
if char then
char:FindFirstChild("HumanoidRootPart").Anchored = true
end

DroneCamera = Instance.new("Camera")
cam.CameraType = Enum.CameraType.Scriptable

local dronePos = char and char:FindFirstChild("HumanoidRootPart") and char.HumanoidRootPart.Position + Vector3.new(0,5,0) or Vector3.new(0,5,0)
cam.CFrame = CFrame.new(dronePos)

-- Botões na tela
local Gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
Gui.Name = "DroneGui"

local function createButton(name, pos, text)
local btn = Instance.new("TextButton")
btn.Size = UDim2.new(0,50,0,50)
btn.Position = pos
btn.Text = text
btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
btn.TextColor3 = Color3.fromRGB(255,255,255)
btn.Parent = Gui
return btn
end

local BtnLeft = createButton("Left", UDim2.new(0,10,0.9,0), "<")
local BtnRight = createButton("Right", UDim2.new(0,70,0.9,0), ">")
local BtnUp = createButton("Up", UDim2.new(0,130,0.9,0), "^")
local BtnDown = createButton("Down", UDim2.new(0,190,0.9,0), "v")

local moveDir = Vector3.new(0,0,0)
local function updateMove()
local cf = cam.CFrame
local forward = cf.LookVector
local right = cf.RightVector
cam.CFrame = cf + (forward * moveDir.Z + right * moveDir.X + Vector3.new(0,moveDir.Y,0)) * DroneSpeed * RunService.RenderStepped:Wait()
end

BtnLeft.MouseButton1Down:Connect(function() moveDir = Vector3.new(-1,0,0) end)
BtnLeft.MouseButton1Up:Connect(function() moveDir = Vector3.new(0,0,0) end)
BtnRight.MouseButton1Down:Connect(function() moveDir = Vector3.new(1,0,0) end)
BtnRight.MouseButton1Up:Connect(function() moveDir = Vector3.new(0,0,0) end)
BtnUp.MouseButton1Down:Connect(function() moveDir = Vector3.new(0,0,1) end)
BtnUp.MouseButton1Up:Connect(function() moveDir = Vector3.new(0,0,0) end)
BtnDown.MouseButton1Down:Connect(function() moveDir = Vector3.new(0,0,-1) end)
BtnDown.MouseButton1Up:Connect(function() moveDir = Vector3.new(0,0,0) end)

-- Touch / drag para olhar
local UIS = game:GetService("UserInputService")
UIS.InputBegan:Connect(function(input)
if input.UserInputType == Enum.UserInputType.Touch then
TouchControl[input.UserInputState] = input.Position
end
end)
UIS.InputChanged:Connect(function(input)
if input.UserInputType == Enum.UserInputType.Touch then
if TouchControl[input] then
local delta = input.Position - TouchControl[input]
local cf = cam.CFrame
cam.CFrame = cf * CFrame.Angles(0,-delta.X/200,0) * CFrame.Angles(-delta.Y/200,0,0)
TouchControl[input] = input.Position
end
end
end)

-- Loop de movimento
RunService.RenderStepped:Connect(function()
if DroneEnabled then
local cf = cam.CFrame
local forward = cf.LookVector
local right = cf.RightVector
cam.CFrame = cf + (forward * moveDir.Z + right * moveDir.X + Vector3.new(0,moveDir.Y,0)) * DroneSpeed * RunService.RenderStepped:Wait()
end
end)

else
-- Desativar drone e resetar câmera
cam.CameraType = Enum.CameraType.Custom
if char then
char:FindFirstChild("HumanoidRootPart").Anchored = false
end
if player.PlayerGui:FindFirstChild("DroneGui") then
player.PlayerGui.DroneGui:Destroy()
end
end

end

})
